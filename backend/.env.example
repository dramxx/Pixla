# Pixla Backend Configuration

# Server
HOST=localhost
PORT=8000
DEBUG=false

# Database
DB_PATH=./pixla.db

# Storage
STORAGE_PATH=./storage

# AI - Model settings 
MODEL_DEVICE=cuda
MODEL_DTYPE=float16

# Local LLM 
LLM_HOST=localhost
LLM_PORT=8081 
LLM_MODEL=qwen2.5-7b-instruct
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

