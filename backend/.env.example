# Pixla Backend Configuration

HOST=localhost
PORT=8000
DEBUG=false

# Database
DB_PATH=./pixla.db

# Storage
STORAGE_PATH=./storage

# AI - Model settings (model loaded from storage/models, configure device/dtype)
MODEL_DEVICE=cuda
MODEL_DTYPE=float16

# Local LLM (for pixel agent)
LLM_HOST=localhost
LLM_PORT=8080
LLM_MODEL=llama3
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

