# Pixla Backend Configuration

HOST=0.0.0.0
PORT=8000
DEBUG=false

# Database
DB_PATH=./pixla.db

# Storage
STORAGE_PATH=./storage

# AI - Default Model
MODEL_ID=runwayml/stable-diffusion-v1-5
MODEL_DEVICE=cuda
MODEL_DTYPE=float16
MODEL_DEFAULT_STEPS=20
MODEL_DEFAULT_GUIDANCE=7.5

# Local LLM (for pixel agent)
LLM_HOST=localhost
LLM_PORT=8080
LLM_MODEL=llama3
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# Optional: API fallback (if local model fails or as agent)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
