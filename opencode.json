{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "provider": {
    "local": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Local (llama.cpp)",
      "options": {
        "baseURL": "http://127.0.0.1:8080/v1",
        "apiKey": "none"
      },
      "models": {
        "local/qwen3-14b": {
          "name": "Qwen3-14B",
          "tools": true
        }
      }
    }
  },
  "mcp": {
    "playwright": { //Missing property "type".
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ]
    }
  },
  "permission": {
    "edit": "allow",
    "bash": "ask",
    "webfetch": "ask"
  }
}